    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "simple-git": "^3.36.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
