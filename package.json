    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build:lib": "tsup",
    "build:web": "vite build",
    "build": "npm run build:lib && npm run build:web",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.43.0",
