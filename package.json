    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fast-glob": "^3.3.3",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-components": "^1.5.4",
    "graphology-dag": "^0.4.1",
    "graphology-shortest-path": "^2.1.0",
    "ignore": "^7.0.5",
